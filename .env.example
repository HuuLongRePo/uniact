
# Authentication
JWT_SECRET=replace-with-a-long-random-secret

# WebAuthn Configuration
WEBAUTHN_ORIGIN=http://localhost:3000

# Biometric Features
BIOMETRIC_SECRET=your-biometric-encryption-key

# Cron Jobs Security
CRON_SECRET=your-cron-secret-key

# Admin Setup (only for initial setup, comment out after first run)
# ADMIN_EMAIL=admin@school.edu
# ADMIN_PASSWORD=change-this-strong-password!

# App URL (for password reset links, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Internet Blocking (for mobile/LAN restriction)
NEXT_PUBLIC_BLOCK_INTERNET=false

# Auto-publish Activities
AUTO_PUBLISH=false

# Feature Flags
ENABLE_BIOMETRICS=true
ENABLE_WEBAUTHN=true
ENABLE_SECURITY_QUESTIONS=true
ENABLE_BONUS_SYSTEM=true

# Performance & Optimization
DATABASE_CACHE_TTL=300000
# 300000ms = 5 minutes

# Backup Configuration
BACKUP_DIR=./backups
BACKUP_INTERVAL=86400000
# 86400000ms = 24 hours
