{
  "name": "uniact",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:lan": "next dev --turbopack -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "release:check": "node scripts/maintenance/release-check.mjs --mode=full",
    "release:check:fast": "node scripts/maintenance/release-check.mjs --mode=fast",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "test": "vitest run --reporter dot",
    "test:core-flows": "vitest run --reporter dot test/approval-workflow.test.ts test/attendance.test.ts test/activities.test.ts",
    "test:admin-report-routes": "vitest run --reporter dot test/admin-report-routes.test.ts test/participation-report-route.test.ts test/participation-report-options.test.ts",
    "test:admin-report-pages": "vitest run --reporter dot test/participation-report-page.test.tsx test/custom-report-page.test.tsx test/teachers-report-page.test.tsx test/scores-report-page.test.tsx test/activity-statistics-report-page.test.tsx",
    "test:backbone": "vitest run --reporter dot --pool threads --no-file-parallelism test/approval-workflow.test.ts test/attendance.test.ts test/activities.test.ts test/admin-report-routes.test.ts test/participation-report-route.test.ts test/participation-report-options.test.ts test/participation-report-page.test.tsx test/custom-report-page.test.tsx test/teachers-report-page.test.tsx test/scores-report-page.test.tsx test/activity-statistics-report-page.test.tsx",
    "test:admin-reports": "vitest run --reporter dot test/admin-report-routes.test.ts test/participation-report-route.test.ts test/participation-report-options.test.ts test/participation-report-page.test.tsx test/custom-report-page.test.tsx test/teachers-report-page.test.tsx test/scores-report-page.test.tsx test/activity-statistics-report-page.test.tsx",
    "test:e2e": "playwright test --reporter=dot",
    "test:activity-contract": "node scripts/tests/test-activity-contract.mjs",
    "backup-db": "npx tsx scripts/maintenance/backup-db.ts",
    "seed": "npx tsx scripts/seed/seed-data.ts --mode=demo",
    "seed:reset": "npx tsx scripts/seed/seed-data.ts --mode=reset",
    "seed:minimal": "npx tsx scripts/seed/seed-data.ts --mode=minimal",
    "seed:enhanced": "npx tsx scripts/seed/seed-data.ts --mode=enhanced",
    "seed:qa": "npx tsx scripts/seed/seed-data.ts --mode=qa",
    "validate": "npx tsx scripts/maintenance/validate-project.ts --mode=all",
    "validate:schema": "npx tsx scripts/maintenance/validate-project.ts --mode=schema",
    "validate:data": "npx tsx scripts/maintenance/validate-project.ts --mode=data",
    "validate:indexes": "npx tsx scripts/maintenance/validate-project.ts --mode=indexes",
    "audit:routes": "npx tsx scripts/maintenance/route-audit.ts",
    "audit:i18n": "npx tsx scripts/maintenance/i18n-audit.ts",
    "fix": "npx tsx scripts/maintenance/fix-project.ts --mode=all",
    "fix:queries": "npx tsx scripts/maintenance/fix-project.ts --mode=api-queries",
    "fix:schema": "npx tsx scripts/maintenance/fix-project.ts --mode=schema",
    "fix:dry-run": "npx tsx scripts/maintenance/fix-project.ts --mode=dry-run",
    "db:migrate": "npx tsx scripts/migrations/run.ts",
    "db:setup": "npm run db:migrate && npm run seed",
    "benchmark": "node scripts/tools/benchmark.mjs",
    "load-test": "artillery run scripts/load-test.yml",
    "health-check": "node scripts/tools/health-check.mjs",
    "logs": "node scripts/tools/logs.mjs",
    "system-info": "node scripts/tools/system-info.mjs",
    "production:build": "node scripts/tools/run-with-node-env.mjs production build",
    "production:start": "node scripts/tools/run-with-node-env.mjs production start",
    "jobs:start": "node scripts/background-jobs.js",
    "jobs:test": "node scripts/auto-complete-activities.js",
    "cleanup": "node cleanup.js",
    "cleanup:dry-run": "node cleanup.js --dry-run",
    "cleanup:soft": "node cleanup.js --no-nodemodules"
  },
  "dependencies": {
    "@simplewebauthn/browser": "^10.0.0",
    "@simplewebauthn/server": "^10.0.0",
    "@tensorflow/tfjs": "^4.13.0",
    "argon2": "^0.40.3",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "cookie": "^1.0.2",
    "date-fns": "^4.1.0",
    "encoding": "^0.1.13",
    "exceljs": "^4.4.0",
    "face-api.js": "^0.22.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.545.0",
    "next": "15.5.15",
    "node-cron": "^3.0.3",
    "papaparse": "^5.5.3",
    "qrcode": "^1.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hot-toast": "^2.6.0",
    "react-qr-code": "^2.0.18",
    "recharts": "^3.4.1",
    "sqlite3": "^6.0.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsdom": "^27.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.25",
    "@types/papaparse": "^5.5.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.4",
    "canvas": "^3.2.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.15",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.8.9",
    "jsdom": "^27.2.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "brace-expansion": "^2.0.2",
    "picomatch": "^4.0.4"
  }
}
